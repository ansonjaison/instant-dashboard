# LLM API credentials (required)
LLM_API_KEY=your_api_key_here

# Model to use (optional — defaults shown below)
# OpenCode Zen (recommended):
LLM_MODEL=minimax-m2.5-free
LLM_API_URL=https://opencode.ai/zen/v1/chat/completions

# NVIDIA NIM alternative:
# LLM_MODEL=meta/llama-3.1-8b-instruct
# LLM_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
